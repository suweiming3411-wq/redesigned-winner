import math
from turtle import *

def hearta(k):
    return 16 * math.sin(k) ** 3

def heartb(k):
    return 13 * math.cos(k) - 5 * math.cos(2*k) - 2 * math.cos(3*k) - math.cos(4*k)

speed(0)
bgcolor("black")
pensize(2)

for i in range(1000):
    x = hearta(i) * 15
    y = heartb(i) * 15
    goto(x, y)
    r = 0.5 + 0.5 * math.sin(i/50)
    g = 0.5 + 0.5 * math.sin(i/30 + 2)
    b = 0.5 + 0.5 * math.sin(i/40 + 4)
    color(r, g, b)

goto(0,0)
done()
